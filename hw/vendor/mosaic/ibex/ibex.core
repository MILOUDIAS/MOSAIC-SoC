CAPI=2:

# Ibex RV32 core (lowRISC) — MOSAIC-SoC vendored copy.
#
# The Ibex RTL was taken from a newer lowRISC tree than x-heep's OpenTitan
# snapshot.  Do not compile Ibex's duplicate prim/prim_generic closure beside
# x-heep: packages and modules such as prim_pkg, prim_buf, prim_flop and
# prim_ram_1p would be defined twice in a heterogeneous full-SoC build.
#
# Instead this descriptor reuses the shared lowrisc:prim:* VLNVs already used
# by cv32e20/x-heep.  Only primitives absent from that snapshot remain local:
# the inverse SECDED codecs and prim_count.  The generated MOSAIC Ibex profile
# keeps cache and SecureIbex disabled; compatibility shims let those parameter
# branches elaborate against the older RAM API, but they remain outside the
# config schema and are not functionally qualified by the SoC flow.

name: mosaic:ip:ibex
description: "Ibex RV32 core (lowRISC) using x-heep's shared OpenTitan primitives"
license: Apache-2.0

filesets:
  rtl:
    depend:
      # Reuse x-heep/OpenTitan's single primitive namespace.  These VLNVs
      # supply their own generated generic implementations and include roots.
      - lowrisc:dv:dv_fcov_macros
      - lowrisc:prim:assert
      - lowrisc:prim:buf
      - lowrisc:prim:clock_gating
      - lowrisc:prim:clock_mux2
      - lowrisc:prim:flop
      - lowrisc:prim:lfsr
      - lowrisc:prim:ram_1p
      - lowrisc:prim:ram_1p_scr
    files:
      # --- packages first (declaration order matters) ---
      - vendor/prim/rtl/prim_count_pkg.sv
      - rtl/ibex_pkg.sv
      # --- primitives absent from x-heep's OpenTitan snapshot ---
      - vendor/prim/rtl/prim_count.sv
      - vendor/prim/rtl/prim_secded_inv_28_22_dec.sv
      - vendor/prim/rtl/prim_secded_inv_28_22_enc.sv
      - vendor/prim/rtl/prim_secded_inv_39_32_dec.sv
      - vendor/prim/rtl/prim_secded_inv_39_32_enc.sv
      # --- ibex core ---
      - rtl/ibex_alu.sv
      - rtl/ibex_branch_predict.sv
      - rtl/ibex_compressed_decoder.sv
      - rtl/ibex_controller.sv
      - rtl/ibex_counter.sv
      - rtl/ibex_cs_registers.sv
      - rtl/ibex_csr.sv
      - rtl/ibex_decoder.sv
      - rtl/ibex_dummy_instr.sv
      - rtl/ibex_ex_block.sv
      - rtl/ibex_fetch_fifo.sv
      - rtl/ibex_icache.sv
      - rtl/ibex_id_stage.sv
      - rtl/ibex_if_stage.sv
      - rtl/ibex_load_store_unit.sv
      - rtl/ibex_multdiv_fast.sv
      - rtl/ibex_multdiv_slow.sv
      - rtl/ibex_pmp.sv
      - rtl/ibex_prefetch_buffer.sv
      - rtl/ibex_register_file_ff.sv
      - rtl/ibex_register_file_fpga.sv
      - rtl/ibex_register_file_latch.sv
      - rtl/ibex_lockstep.sv
      - rtl/ibex_wb_stage.sv
      - rtl/ibex_core.sv
      - rtl/ibex_top.sv
    file_type: systemVerilogSource

targets:
  default:
    filesets:
      - rtl
    toplevel: ibex_top
