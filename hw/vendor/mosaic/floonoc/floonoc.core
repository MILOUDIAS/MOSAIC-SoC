CAPI=2:

# Vendored FlooNoC RTL library (pulp-platform/FlooNoC, Solderpad SHL-0.51),
# single-AXI ("network_type: axi") subset: routers, AXI chimneys, links.
# Excluded vs upstream Bender.yml: the narrow-wide modules (floo_nw_*, pull
# iDMA/FPnew) and hw/test + hw/tb. The fabric top (floo_mosaic_noc.sv) is
# GENERATED by floogen via util/xheep_gen/floonoc_gen.py — see
# hw/ip/floonoc_fabric/ (mosaic:ip:floonoc_fabric).
name: mosaic:ip:floonoc:0.1.0
description: FlooNoC AXI NoC library (vendored, single-AXI subset)

filesets:
  files_rtl:
    depend:
    - pulp-platform.org::axi:0.39.8
    - pulp-platform.org::common_cells:1.38.0
    files:
    - hw/include/floo_noc/typedef.svh: {is_include_file: true, include_path: hw/include}
    - hw/floo_pkg.sv
    - hw/floo_cut.sv
    - hw/floo_fifo.sv
    - hw/floo_cdc.sv
    - hw/floo_route_select.sv
    - hw/floo_id_translation.sv
    - hw/floo_vc_arbiter.sv
    - hw/floo_wormhole_arbiter.sv
    - hw/floo_simple_rob.sv
    - hw/floo_rob.sv
    - hw/floo_rob_wrapper.sv
    - hw/floo_reduction_sync.sv
    - hw/floo_route_xymask.sv
    - hw/floo_alu.sv
    - hw/floo_meta_buffer.sv
    - hw/floo_reduction_arbiter.sv
    - hw/floo_reduction_unit.sv
    - hw/floo_output_arbiter.sv
    - hw/floo_axi_chimney.sv
    - hw/floo_router.sv
    - hw/floo_axi_router.sv
    file_type: systemVerilogSource

targets:
  default:
    filesets:
    - files_rtl
