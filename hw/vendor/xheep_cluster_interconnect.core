CAPI=2:

name: x-heep:ip:cluster_interconnect

# Copyright 2021 OpenHW Group
# Solderpad Hardware License, Version 2.1, see LICENSE.md for details.
# SPDX-License-Identifier: Apache-2.0 WITH SHL-2.1

filesets:
  files_rtl:
    files:
    - xheep/cluster_interconnect/rtl/tcdm_variable_latency_interconnect/xbar_varlat.sv
    - xheep/cluster_interconnect/rtl/tcdm_variable_latency_interconnect/addr_dec_resp_mux_varlat.sv
    file_type: systemVerilogSource

  # Classic fixed-latency logarithmic interconnect (MOSAIC `bus: log`).
  # The RTL was already vendored (upstream pulp-platform/cluster_interconnect)
  # but not compiled; amo_shim.sv is skipped (x-heep OBI has no atomics).
  files_rtl_tcdm:
    files:
    - xheep/cluster_interconnect/rtl/tcdm_interconnect/tcdm_interconnect_pkg.sv
    - xheep/cluster_interconnect/rtl/tcdm_interconnect/tcdm_interconnect.sv
    - xheep/cluster_interconnect/rtl/tcdm_interconnect/xbar.sv
    - xheep/cluster_interconnect/rtl/tcdm_interconnect/addr_dec_resp_mux.sv
    - xheep/cluster_interconnect/rtl/tcdm_interconnect/bfly_net.sv
    - xheep/cluster_interconnect/rtl/tcdm_interconnect/clos_net.sv
    file_type: systemVerilogSource

targets:
  default:
    filesets:
    - files_rtl
    - files_rtl_tcdm
